# Production environment variables for SecureBank backend

# PostgreSQL datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:5432/securebank
SPRING_DATASOURCE_USERNAME=<PROD_DB_USER>
SPRING_DATASOURCE_PASSWORD=<PROD_DB_PASSWORD>

# JPA settings
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# Redis
SPRING_REDIS_HOST=<REDIS_HOST>
SPRING_REDIS_PORT=<REDIS_PORT>

# JWT settings
JWT_SECRET=<YOUR_SECURE_JWT_SECRET>
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Payment provider credentials
RAZORPAY_KEY_ID=<YOUR_RAZORPAY_KEY_ID>
RAZORPAY_KEY_SECRET=<YOUR_RAZORPAY_KEY_SECRET>
STRIPE_API_KEY=<YOUR_STRIPE_API_KEY>
STRIPE_ENDPOINT_SECRET=<YOUR_STRIPE_ENDPOINT_SECRET>

# Allowed CORS origins (comma-separated)
APP_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Server port
SERVER_PORT=8080
